pipeline {
    agent any
    environment {
        NETLIFY_SITE_ID = 'nfp_N69QcaxQKw4KmcnptHX1PMCzzZaFBGyM1f0a'
        NETLIFY_AUTH_TOKEN = credentials('netlify-auth-token')
    }
    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:20.16.0-slim'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version
                    npm install
                    npm run build
                    ls -la
                '''
            }
        }
        stage('Test') {
            agent {
                docker {
                    image 'node:20.16.0-slim'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    test -f build/index.html
                    npm test
                '''
            }
        stage('Deploy') {
            agent {
                docker {
                    image 'node:20.16.0-slim'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    npm install netlify-cli
                    node_modules/.bin/netlify --version
                    echo "Site ID: $NETLIFY_SITE_ID"
                    node_modules/.bin/netlify status
                    node_modules/.bin/netlify deploy --prod --dir=build
                '''
            }
        }
    }
}
}